# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored - it will never be committed.
zone_id     = "your-zone-id-here"
domain_name = "yourdomain.com"

# Do NOT put cloudflare_api_token in a .tfvars file, even a gitignored one.
# Set it as an environment variable instead, right before running terraform:
#   export TF_VAR_cloudflare_api_token="your-real-token"
